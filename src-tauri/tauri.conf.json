{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "跨境利通",
  "version": "0.1.0",
  "identifier": "com.kuajinglitong.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "跨境利通",
        "width": 1280,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "nsis": {
        "installerIcon": null,
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"],
        "installMode": "perMachine"
      }
    },
    "icon": []
  }
}
